{
  "name": "pi-side-agents",
  "version": "1.1.1",
  "description": "Side-agent orchestration for Pi — spin off parallel child agents in tmux windows and git worktrees.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "parallel",
    "agent",
    "subagent",
    "tmux",
    "worktree"
  ],
  "files": [
    "extensions/",
    "skills/",
    "docs/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test:unit": "node --test tests/unit/tool-contract.test.mjs",
    "test:integration": "node --test --test-concurrency=1 tests/integration/side-agents.integration.test.mjs"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  }
}
